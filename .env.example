# Copy to .env and fill in. The .env file is NOT committed to git.

# --- PostgreSQL ---
POSTGRES_DB=tracker
POSTGRES_USER=tracker
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# --- Application ports ---
BACKEND_PORT=8080
FRONTEND_PORT=80

# --- Google OAuth2 (required to log in; stack boots without them) ---
# Authorized redirect URI in Google console: http://localhost/login/oauth2/code/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- OLX partner API (optional; scraper source) ---
OLX_ACCESS_TOKEN=
