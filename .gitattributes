# Default: git normalizes line endings to LF in the repo and the working tree.
* text=auto eol=lf

# Shell scripts always LF (otherwise they won't run on Linux/CI).
*.sh text eol=lf

# Windows batch files always CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binaries - no line-ending normalization.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.jar  binary
*.woff  binary
*.woff2 binary
